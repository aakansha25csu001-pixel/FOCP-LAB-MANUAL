#include<iostream>
using namespace std;//semi colon
int main()
{
    int n;
    cout<<"Enter number of terms: ";//semi color
    cin>>n;//syntax error
    if(n <= 0)
    {
        cout<<"Invalid Input";//semi colon is missing
    }

    int a = 0, b = 1, c;
    cout<<a<<" "<<b<<" ";
    for(int i = 3; i <= n; i++)
    {
        c = a + b;//semi colon
        cout<<c<<" ";
        a = b;
        b = c;
    }
    return 0; //semi colon
}

